expression Statement-Elements =
		let
		    Workbook= Excel.Workbook(File.Contents(Files & "Statement.xlsx"), null, true),
		    Sheet = Workbook{[Item="Elements",Kind="Sheet"]}[Data],
		    Elements = Table.PromoteHeaders(Sheet, [PromoteAllScalars=true]),
		    #"Changed Type" = Table.TransformColumnTypes(Elements,{{"Element", type text}, {"FromAccountNo", Int64.Type}, {"ToAccountNo", Int64.Type}, {"Signage", Int64.Type}}),
		    #"Added Custom" = Table.AddColumn(#"Changed Type", "FromToAccountNo", each {[FromAccountNo]..[ToAccountNo]}),
		    #"Expanded FromToAccountNo" = Table.ExpandListColumn(#"Added Custom", "FromToAccountNo"),
		    #"Changed Type1" = Table.TransformColumnTypes(#"Expanded FromToAccountNo",{{"FromToAccountNo", Int64.Type}}),
		    #"Merged Queries" = Table.NestedJoin(#"Changed Type1", {"FromToAccountNo"}, Account, {"Account Code"}, "Account", JoinKind.Inner),
		    #"Expanded Account" = Table.ExpandTableColumn(#"Merged Queries", "Account", {"AccountKey"}, {"AccountKey"}),
		    #"Removed Columns" = Table.RemoveColumns(#"Expanded Account",{"FromAccountNo", "ToAccountNo", "FromToAccountNo"})
		in
		    #"Removed Columns"
	lineageTag: d5f65308-9e42-4290-b94e-191e66f41aba
