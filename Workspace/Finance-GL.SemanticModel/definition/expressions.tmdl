	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression Stastement-Metric =
		let
		    Workbook = Excel.Workbook(File.Contents(Files & "Statement.xlsx"), null, true),
		    Sheet = Workbook{[Item="Metrics", Kind="Sheet"]}[Data],
		    Elements = Table.PromoteHeaders(Sheet, [PromoteAllScalars=true]),
		
		    #"Added Index" =
		        Table.AddIndexColumn(Elements, "Index", 1, 1, Int64.Type),
		
		    #"Sorted Rows" =
		        Table.Sort(
		            #"Added Index",
		            {
		                {"Metric", Order.Ascending},
		                {"Index", Order.Ascending}
		            }
		        ),
		
		    Grouped =
		        Table.Group(
		            #"Sorted Rows",
		            {"Metric"},
		            {
		                {
		                    "Data",
		                    (t) => Table.AddIndexColumn(t, "Ordinal", 1, 1, Int64.Type)
		                }
		            },
		            GroupKind.Local
		        ),
		
		    Expanded =
		        Table.ExpandTableColumn(
		            Grouped,
		            "Data",
		            {"Index","Element","MetricType","Signage","Ordinal"}
		        ),
		
		    #"Changed Type1" =
		        Table.TransformColumnTypes(
		            Expanded,
		            {
		                {"Index", Int64.Type},
		                {"Element", type text},
		                {"Metric", type text},
		                {"Signage", Int64.Type},
		                {"Ordinal", Int64.Type},
		                {"MetricType", type text}
		            }
		        ),
		
		    MetricIDTable =
		        Table.Group(
		            #"Changed Type1",
		            {"Metric"},
		            {
		                {"MetricID", each List.Min([Index]), Int64.Type}
		            }
		        ),
		
		    #"Merged MetricID" =
		        Table.NestedJoin(
		            #"Changed Type1",
		            {"Metric"},
		            MetricIDTable,
		            {"Metric"},
		            "MetricID",
		            JoinKind.LeftOuter
		        ),
		
		    #"Expanded MetricID" =
		        Table.ExpandTableColumn(
		            #"Merged MetricID",
		            "MetricID",
		            {"MetricID"}
		        ),
		    #"Reordered Columns" = Table.ReorderColumns(#"Expanded MetricID",{"MetricID", "Metric", "Index", "Element", "MetricType", "Signage", "Ordinal"}),
		    #"Renamed Columns" = Table.RenameColumns(#"Reordered Columns",{{"MetricID", "Metric ID"}, {"MetricType", "Metric Type"}})
		in
		    #"Renamed Columns"
	lineageTag: 2613fcb0-3aa0-49c6-a4fc-e615dcb28094
	queryGroup: Hidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression Stastement-Hierarchy =
		let
		    SourceM = #"Stastement-Metric",
		    Source0 = Table.SelectColumns(SourceM, {"Metric ID","Metric","Element","Metric Type","Ordinal"}),
		    Source = Table.Distinct(Source0),
		
		    Metrics = List.Distinct(Source[Metric]),
		
		    Expand1 =
		        Table.NestedJoin(Source, {"Element"}, Source, {"Metric"}, "L1", JoinKind.LeftOuter),
		
		    Expand1a =
		        Table.ExpandTableColumn(Expand1, "L1", {"Element"}, {"Level1"}),
		
		    Expand2 =
		        Table.NestedJoin(Expand1a, {"Level1"}, Source, {"Metric"}, "L2", JoinKind.LeftOuter),
		
		    Expand2a =
		        Table.ExpandTableColumn(Expand2, "L2", {"Element"}, {"Level2"}),
		
		    Expand3 =
		        Table.NestedJoin(Expand2a, {"Level2"}, Source, {"Metric"}, "L3", JoinKind.LeftOuter),
		
		    Expand3a =
		        Table.ExpandTableColumn(Expand3, "L3", {"Element"}, {"Level3"}),
		
		    Expand4 =
		        Table.NestedJoin(Expand3a, {"Level3"}, Source, {"Metric"}, "L4", JoinKind.LeftOuter),
		
		    Expand4a =
		        Table.ExpandTableColumn(Expand4, "L4", {"Element"}, {"Level4"}),
		
		    Expand5 =
		        Table.NestedJoin(Expand4a, {"Level4"}, Source, {"Metric"}, "L5", JoinKind.LeftOuter),
		
		    Expand5a =
		        Table.ExpandTableColumn(Expand5, "L5", {"Element"}, {"Level5"}),
		
		    AddLeaf =
		        Table.AddColumn(
		            Expand5a,
		            "LeafElement",
		            each
		                let
		                    path =
		                        {
		                            [Element],
		                            [Level1],
		                            [Level2],
		                            [Level3],
		                            [Level4],
		                            [Level5]
		                        },
		
		                    leaf =
		                        List.First(
		                            List.Select(
		                                path,
		                                (x)=> x <> null and not List.Contains(Metrics,x)
		                            ),
		                            List.Last(List.RemoveNulls(path))
		                        )
		                in
		                    leaf,
		            type text
		        ),
		
		    Result =
		        Table.SelectColumns(
		            AddLeaf,
		            {
		                "Metric ID",
		                "Metric",
		                "Element",
		                "Metric Type",
		                "Level1",
		                "Level2",
		                "Level3",
		                "Level4",
		                "Level5",
		                "LeafElement","Ordinal"
		            }
		        ),
		    #"Renamed Columns" = Table.RenameColumns(Result,{{"Element", "Level 1"}, {"Level1", "Level 2"}, {"Level2", "Level 3"}, {"Level3", "Level 4"}, {"Level4", "Level 5"}, {"Level5", "Level 6"}, {"LeafElement", "Element"}}),
		    #"Merged Queries" = Table.NestedJoin(#"Renamed Columns", {"Element"}, #"Statement-Elements", {"Element"}, "Statement-Elements", JoinKind.LeftOuter),
		    #"Expanded Statement-Elements" = Table.ExpandTableColumn(#"Merged Queries", "Statement-Elements", {"Signage", "AccountKey"}, {"Signage", "AccountKey"}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Expanded Statement-Elements",{{"Signage", "Element Signage"}})
		in
		    #"Renamed Columns1"
	lineageTag: 7a83c267-2043-4643-863a-064f4b665b2d
	queryGroup: Hidden

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression 'Unique Metrics' =
		let
		    Source = #"Stastement-Metric",
		    #"Grouped Rows" = Table.Group(Source, {"Metric"}, {{"Metric ID", each List.Min([Metric ID]), type nullable number}}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Grouped Rows",{{"Metric ID", Int64.Type}})
		in
		    #"Changed Type"
