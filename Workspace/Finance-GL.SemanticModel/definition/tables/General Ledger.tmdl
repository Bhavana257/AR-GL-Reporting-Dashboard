	measure 'Metric Value' =
			
			VAR MetricType= if(HASONEVALUE(Metrics[Level 1]), "", SELECTEDVALUE(Metrics[Metric Type]))
			RETURN
			switch (MetricType
			, "Percentage", [GL Amount KPI]
			, [GL Amount])
		displayFolder: _Metric
		lineageTag: e4a4cfde-d71a-468b-91fd-3634d8747062

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Budget = CALCULATE([Metric Value], Scenario[Scenario] ="Budget")
