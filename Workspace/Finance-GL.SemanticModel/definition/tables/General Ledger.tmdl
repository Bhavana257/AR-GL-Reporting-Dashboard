				    #"Merged Queries" = Table.NestedJoin(#"Changed Type1", {"AccountKey"}, Account, {"AccountKey"}, "Account", JoinKind.Inner),
				    #"Expanded Account1" = Table.ExpandTableColumn(#"Merged Queries", "Account", {"Account Type"}, {"Account Type"}),
				    #"Apply Operator (+/-)" = Table.AddColumn(#"Expanded Account1", "BaseAmount", each ([Amount]  * (if [Account Type]="Expenditures" or [Account Type]="Liabilities" then -1 else 1 ))),
