table 'General Ledger'
	lineageTag: d5752805-8ab9-47a6-97e9-298dfa17e7ad

	measure 'GL Amount' = ```
			
			VAR s =   SELECTEDVALUE(Scenario[Scenario],"Actual") RETURN   CALCULATE(sum('General Ledger'[BaseAmount] ), Scenario[Scenario] =s)     
			```
		formatString: #,0.00
		lineageTag: 03eebc76-04dc-401a-bd1a-34b13861197a

	measure 'GL Budget' = ```
			VAR s =   SELECTEDVALUE(Scenario[Scenario],"Budget") RETURN   CALCULATE([GL Amount], Scenario[Scenario] =s) 
			```
		formatString: #,0.00
		displayFolder: _GL
		lineageTag: 476092d9-2f83-4aa1-8bc6-0b679b62b85e

	measure 'GL Variance' = [GL Actual] -[GL Budget]
		formatString: #,0.00
		displayFolder: _GL
		lineageTag: 22b3015e-a473-44e7-a13d-49963f593c66

	measure 'GL Variance%' = ```
			DIVIDE([GL Variance] ,[GL Budget])
			
			```
		displayFolder: _GL
		lineageTag: 4be609d4-14ca-48ff-bb61-7e5d04ea410f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'GL Opening Balance' = var MaxPeriod =MIN('Date'[Fiscal Period No] ) RETURN CALCULATE( [GL Amount] , all('Date'), 'Date'[Fiscal Period No] < MaxPeriod)
		formatString: #,0
		displayFolder: _GL
		lineageTag: 303e507a-8127-4953-884b-480ff48e69fb

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'GL Closing Balance' = var MaxPeriod =max('Date'[Fiscal Period No] ) RETURN CALCULATE( [GL Amount] , all('Date'), 'Date'[Fiscal Period No] <= MaxPeriod)
		formatString: #,0
		displayFolder: _GL
		lineageTag: 8f0f9786-c483-4b5d-ab50-db02664bca0f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'GL Movement' = ```
			[GL Amount] 
			```
		formatString: #,0
		displayFolder: _GL
		lineageTag: 63216da7-5015-4ae0-8701-ca15cff58345

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'GL Amount Value' = ```
			VAR s =   SELECTEDVALUE(Scenario[Scenario],"Actual") RETURN   CALCULATE(sum('General Ledger'[BaseAmount] ), Scenario[Scenario] =s)     
			```
		formatString: #,0
		displayFolder: _Internal
		lineageTag: 1f6ea3d2-7471-451a-8ded-38274565ba30

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'GL Amount KPI' = ```
			
			var a = CALCULATE([GL Amount], Metrics[Ordinal]=1)
			var b = CALCULATE([GL Amount], Metrics[Ordinal]=2)
			RETURN DIVIDE(a,b)
			
			```
		displayFolder: _Internal
		lineageTag: 635bf0b1-7c7b-4363-80b7-bb3ce4a30fc0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

