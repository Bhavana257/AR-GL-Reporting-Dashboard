		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Δ to Budget' = ```
			[Actual] - [Budget]
			
			```
		displayFolder: _P&L
		lineageTag: 3d8fc1e3-e134-4d95-bbf6-759a1ee34ad0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Δ to Budget%' =
			
			VAR a =[Actual]
			VAR b = [Budget]
			RETURN
			DIVIDE(a-b,b)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: _P&L
		lineageTag: b7b8589c-539a-49d8-8d7a-08c6b4d05945

